		<TargetFramework>net8.0</TargetFramework>
		<CopyRefAssembliesToPublishDirectory>true</CopyRefAssembliesToPublishDirectory>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>$(AssemblyName)</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Umbraco.Cms" Version="13.12.1" />
		<PackageReference Include="Umbraco.Forms" Version="13.4.2" />
		<PackageReference Include="uSync.Complete" Version="13.1.7" />
		<PackageReference Include="uSync.Forms" Version="13.3.0" />
		<PackageReference Include="Azure.Monitor.OpenTelemetry.AspNetCore" Version="1.2.0" />
		<PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="2.23.0" />
		<PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="8.0.19" />
		<PackageReference Include="Serilog.Sinks.ApplicationInsights" Version="3.1.0" />
		<PackageReference Include="Microsoft.ICU.ICU4C.Runtime" Version="72.1.0.3" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\CorporateWebsite.Core\CorporateWebsite.Core.csproj" />
	</ItemGroup>
</Project>
