{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "2df1e5af-6ba9-4c30-a6de-6c3613ddca9d",
        "UseHttps": true
      },
      "Hosting": {
        "Debug": true,
        "ServerRole": ""
      }
    }
  },
  "AppConfig": {
    "GtmContainerId": "__GoogleTagManager-Container__",
    "ExternalBlogUrl": "__ExternalBlogUrl__",
    "CorporateSiteBaseUrl": "https://localhost:44377/",
    "EnableBackoffice": true,
    "EnableMediaRedirects": false
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
