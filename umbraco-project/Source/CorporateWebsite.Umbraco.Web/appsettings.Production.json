{
  "$schema": "./appsettings-schema.json",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.ApplicationInsights"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Azure.Messaging.ServiceBus": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "CorporateWebsite.Umbraco.Web"
    }
  },
  "Umbraco": {
    "CMS": {
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Version",
        "Version": "__RuntimeMinificationVersion__"
      }
    }
  },
  "AppConfig": {
    "GtmContainerId": "__GoogleTagManager-Container__",
    "ExternalBlogUrl": "__ExternalBlogUrl__"
  }
}
